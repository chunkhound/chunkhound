---
const dimensions = [
  {
    dimension: "Focus and polish",
    winner: "local",
    local: "One operating mode lets the team polish local indexing, MCP, worktrees, providers, and automatic DB management.",
    mixed: "The product and engineering effort is split between local and server operating modes; each receives less polish.",
  },
  {
    dimension: "Developer scale",
    winner: "local",
    local: "Developer queries run on their own machines. Hundreds or thousands of developers add endpoint work, not shared query load.",
    mixed: "Developers can remain local, but the server mode adds another runtime to build, test, operate, and support.",
  },
  {
    dimension: "Non-developer access",
    winner: "mixed",
    local: "Self-contained DBs remove the checkout dependency. A thin manager can periodically pull and atomically activate fresh versions; a server or CI job can copy, query through a local process, proxy MCP, and exit.",
    mixed: "A central service can enforce one upgrade and authorization boundary, but it is not required merely because the workload runs on a server.",
  },
  {
    dimension: "Deployment shape",
    winner: "local",
    local: "Laptop, server, and CI deployments can use the same local process and DB boundary.",
    mixed: "Introduces a separate central query operating mode in addition to local deployments.",
  },
  {
    dimension: "Cross-repository views",
    winner: "local",
    local: "Users combine the repositories they care about for a personal point of view. The roadmap's DB merge/split tool makes this an advanced configuration, but keeps it operationally simple.",
    mixed: "The service must support repository permutations or implement dynamic cross-DB joins, with authorization, latency, ranking, and failure semantics across sources.",
  },
  {
    dimension: "Index maintenance",
    winner: "local",
    local: "Periodically publish a DB baseline, then let each workload bring its own branch or worktree current with local incremental indexing. Atomic replacement avoids cross-machine live-index maintenance.",
    mixed: "The centralized view needs tighter freshness across every queryable branch while serving reads: growing/sealed segments, WALs, tombstones, compaction, rebuilds, replicas, and shard routing.",
  },
  {
    dimension: "Upgrades and monitoring",
    winner: "mixed",
    local: "A desktop-style manager reduces manual DB work, but endpoint upgrades, monitoring, and failure recovery remain more complex.",
    mixed: "Centralizes upgrades, rollouts, and monitoring, but requires service reliability, capacity, and incident operations.",
  },
  {
    dimension: "Permissions and auth",
    winner: "local",
    local: "Access remains 1:1 with the organization's Git repository permissions and authentication model; local search does not need query-level ANN authorization.",
    mixed: "Centralizes policy and audit, but reliable semantic enforcement needs ACL-aware pre-filtering across the vector index. Post-filtering can underfill results, degrade recall, or force expensive filtered scans.",
  },
  {
    dimension: "Data and freshness",
    winner: "local",
    local: "Centralized object storage periodically publishes a self-contained baseline; local incremental indexing brings each branch or worktree current without a checkout.",
    mixed: "A central live corpus provides one tighter shared view, but must keep every branch synchronized while adding ingestion, consistency, and central data-custody concerns.",
  },
];
---

<div class="comparison-region" role="region" aria-label="Local-first and mixed architecture comparison" tabindex="0">
  <table>
    <caption>
      Incremental trade-offs after the current local-first product baseline.
      <span class="table-key"><strong>Wins</strong> marks the stronger path for each dimension; the other cell shows its alternative.</span>
    </caption>
    <thead>
      <tr>
        <th scope="col">Dimension</th>
        <th scope="col">Focus on local-first</th>
        <th scope="col">Add mixed server path</th>
      </tr>
    </thead>
    <tbody>
      {dimensions.map((row) => (
        <tr>
          <th scope="row">{row.dimension}</th>
          <td class:list={{ winner: row.winner === "local", loser: row.winner === "mixed" }} data-label="Focus on local-first">
            <span class="verdict">{row.winner === "local" ? "Wins" : "Alternative"}</span>
            {row.local}
          </td>
          <td class:list={{ winner: row.winner === "mixed", loser: row.winner === "local" }} data-label="Add mixed server path">
            <span class="verdict">{row.winner === "mixed" ? "Wins" : "Alternative"}</span>
            {row.mixed}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .comparison-region { margin-top: var(--space-6); overflow-x: auto; border: var(--border-w-default) solid var(--border-color); border-radius: var(--radius-xl); background: var(--bg-surface); }
  .comparison-region:focus-visible { outline: var(--border-w-emphasis) solid var(--link-focus); outline-offset: 3px; }
  table { width: 100%; border-collapse: collapse; table-layout: fixed; }
  caption { padding: var(--space-4) var(--space-5); color: var(--text-secondary); font-size: var(--text-sm); line-height: var(--lh-sm); text-align: left; }
  .table-key { display: block; margin-top: var(--space-2); color: var(--text-tertiary); font-size: var(--text-xs); }
  .table-key strong, .verdict { color: var(--primary); font-weight: 700; }
  th, td { padding: var(--space-4) var(--space-5); border-top: var(--border-w-subtle) solid var(--border-color); text-align: left; vertical-align: top; }
  thead th { color: var(--text-primary); background: var(--bg-muted); font-size: var(--text-sm); line-height: var(--lh-sm); }
  thead th:first-child { width: 19%; }
  thead th:not(:first-child) { width: 40.5%; }
  tbody th { color: var(--text-primary); font-size: var(--text-sm); line-height: var(--lh-sm); }
  td { color: var(--text-secondary); font-size: var(--text-sm); line-height: var(--lh-sm); }
  td.winner { background: var(--primary-bg); }
  td.loser { opacity: .78; }
  .verdict { display: block; margin-bottom: var(--space-2); font-size: var(--text-xs); letter-spacing: .08em; text-transform: uppercase; }
  tbody tr:nth-child(even) { background: var(--bg-muted); }
  @media (max-width: 700px) {
    .comparison-region { overflow: visible; border: 0; background: transparent; }
    table, tbody, tr, th, td { display: block; width: 100%; }
    thead { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; }
    caption { padding: 0 0 var(--space-4); }
    tbody tr { margin-bottom: var(--space-4); overflow: hidden; border: var(--border-w-default) solid var(--border-color); border-radius: var(--radius-lg); background: var(--bg-surface); }
    tbody th, td { padding: var(--space-4); border-top: var(--border-w-subtle) solid var(--border-color); }
    tbody th { border-top: 0; background: var(--bg-muted); font-size: var(--text-base); }
    td::before { display: block; margin-bottom: var(--space-2); color: var(--primary); content: attr(data-label); font-size: var(--text-xs); font-weight: 600; letter-spacing: .08em; text-transform: uppercase; }
    td.winner { background: var(--primary-bg); }
  }
</style>
