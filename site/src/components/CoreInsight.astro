---
---

<section id="approach" class="core-insight">
  <div class="container">
    <p class="eyebrow">THE APPROACH</p>
    <h2 class="heading">Deep understanding needs more than search</h2>
    <p class="body">
      ChunkHound parses your code with cAST — AST-aware chunking backed by
      Carnegie Mellon research (<a href="https://arxiv.org/abs/2506.15655" target="_blank" rel="noopener" class="paper-link"><code>arXiv:2506.15655</code></a>). It then grounds answers in the places software understanding actually lives: current code, architecture, git history, external docs, and generated knowledge.
    </p>

    <div class="lens-row">
      <div class="lens-card">
        <ph-magnifying-glass class="lens-icon" size="26" weight="duotone" aria-hidden="true"></ph-magnifying-glass>
        <span class="lens-name">Current code</span>
        <span class="lens-desc">Semantic and regex search</span>
      </div>
      <div class="lens-card">
        <ph-binoculars class="lens-icon" size="26" weight="duotone" aria-hidden="true"></ph-binoculars>
        <span class="lens-name">Architecture</span>
        <span class="lens-desc">Cited cross-file research</span>
      </div>
      <div class="lens-card">
        <ph-clock-counter-clockwise class="lens-icon" size="26" weight="duotone" aria-hidden="true"></ph-clock-counter-clockwise>
        <span class="lens-name">Git history</span>
        <span class="lens-desc">Semantic search over commits, ranges, and branches</span>
      </div>
      <div class="lens-card">
        <ph-globe-hemisphere-west class="lens-icon" size="26" weight="duotone" aria-hidden="true"></ph-globe-hemisphere-west>
        <span class="lens-name">External context</span>
        <span class="lens-desc">Pinpoint web research</span>
      </div>
      <div class="lens-card">
        <ph-book-open-text class="lens-icon" size="26" weight="duotone" aria-hidden="true"></ph-book-open-text>
        <span class="lens-name">Shared knowledge</span>
        <span class="lens-desc">Autodoc from research</span>
      </div>
    </div>
    <div class="hub">
      <div class="hub-line"></div>
      <div class="hub-node"><ph-database size="18" weight="duotone" aria-hidden="true"></ph-database> One codebase context layer</div>
      <div class="hub-line"></div>
    </div>
  </div>
</section>

<script>
  import "@phosphor-icons/webcomponents/PhBinoculars";
  import "@phosphor-icons/webcomponents/PhBookOpenText";
  import "@phosphor-icons/webcomponents/PhClockCounterClockwise";
  import "@phosphor-icons/webcomponents/PhDatabase";
  import "@phosphor-icons/webcomponents/PhGlobeHemisphereWest";
  import "@phosphor-icons/webcomponents/PhMagnifyingGlass";
</script>

<style>
  .core-insight {
    padding: var(--space-10) 0;
    text-align: center;
  }

  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .eyebrow {
    text-transform: uppercase;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--text-tertiary);
    margin-bottom: var(--space-3);
  }

  .heading {
    font-size: var(--text-xl);
    line-height: var(--lh-xl);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }

  .body {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--text-secondary);
    max-width: 720px;
    margin: 0 auto var(--space-7);
  }

  .body .paper-link {
    color: inherit;
    text-decoration: none;
  }

  .body .paper-link:hover code {
    text-decoration: underline;
  }

  .body code {
    background: var(--primary-bg);
    color: var(--on-primary-bg);
    padding: 1px 4px;
    border-radius: var(--radius-sm);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8em;
  }

  .lens-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .lens-card {
    background: var(--bg-surface);
    border: var(--border-w-default) solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: var(--space-4) var(--space-5);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    min-width: 160px;
    text-align: center;
  }

  .lens-icon {
    color: var(--primary);
    margin-bottom: var(--space-1);
  }

  .lens-name {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
  }

  .lens-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .hub {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }

  .hub-line {
    width: var(--space-8);
    height: 1px;
    background: var(--border-color);
  }

  .hub-node {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--primary-bg);
    color: var(--on-primary-bg);
    border: var(--border-w-default) solid var(--primary);
    border-radius: var(--radius-full);
    padding: var(--space-2) var(--space-5);
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-sm);
    font-weight: 600;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .lens-row {
      grid-template-columns: 1fr;
      max-width: 280px;
      margin-left: auto;
      margin-right: auto;
    }

    .hub-line {
      width: var(--space-5);
    }
  }
</style>
