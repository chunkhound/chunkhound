---
interface Props {
    size?: "sm" | "lg";
}
const { size = "sm" } = Astro.props;
---

<span class:list={["wordmark-brand", size]}>
    <span class="wordmark-logo-stack" aria-hidden="true">
        <img src="/logo.svg" alt="" class="wordmark-logo wordmark-logo-light" />
        <img
            src="/logo-light.svg"
            alt=""
            class="wordmark-logo wordmark-logo-dark"
        />
    </span>
    <span class="wordmark-text"
        >ChunkHound<span class="wordmark-dot" aria-hidden="true"></span></span
    >
</span>

<style>
    .wordmark-brand {
        display: inline-flex;
        align-items: center;
        font-family: "Inter", sans-serif;
        font-weight: 700;
        color: var(--text-primary);
    }

    .wordmark-brand.sm {
        font-size: 18px;
        gap: var(--space-2);
    }

    @media (max-width: 420px) {
        .wordmark-brand.sm {
            font-size: 16px;
        }
    }

    .wordmark-brand.lg {
        font-size: clamp(var(--text-3xl), 11vw, var(--text-4xl));
        line-height: 1.15;
        /* display: inline-block so only the text string sets the centering width;
           the logo is pulled out of flow via position:absolute */
        display: inline-block;
        position: relative;
    }

    .wordmark-brand.lg .wordmark-logo-stack {
        position: absolute;
        right: 100%;
        top: 50%;
        transform: translateY(-50%);
        margin-right: var(--space-3);
    }

    /* Mobile: not enough horizontal room to offset the logo — stack it above */
    @media (max-width: 640px) {
        .wordmark-brand.lg {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: var(--space-3);
        }

        .wordmark-brand.lg .wordmark-logo-stack {
            position: static;
            transform: none;
            margin-right: 0;
        }
    }

    .wordmark-logo-stack {
        display: inline-grid;
        place-items: center;
        flex-shrink: 0;
        height: 1.4em;
        width: calc(1.4em * 194 / 150);
    }

    .wordmark-logo {
        grid-area: 1 / 1;
        width: 100%;
        height: 100%;
    }

    .wordmark-logo-dark {
        display: none;
    }

    :global([data-theme="dark"]) .wordmark-logo-light {
        display: none;
    }

    :global([data-theme="dark"]) .wordmark-logo-dark {
        display: block;
    }

    .wordmark-text {
        position: relative;
        white-space: nowrap;
    }

    .wordmark-dot {
        display: inline-block;
        width: 0.14em;
        height: 0.14em;
        border-radius: 50%;
        background: var(--primary-bright);
        margin-left: 1px;
        vertical-align: baseline;
    }
</style>
