---
interface Props {
    size?: "sm" | "lg";
    layout?: "horizontal" | "stacked";
}
const { size = "sm", layout = "horizontal" } = Astro.props;
const isStacked = layout === "stacked";
---

<span class:list={["wordmark-brand", size, layout]}>
    <span class="wordmark-logo-stack" aria-hidden="true">
        <img src="/logo.svg" alt="" class="wordmark-logo wordmark-logo-light" />
        <img
            src="/logo-light.svg"
            alt=""
            class="wordmark-logo wordmark-logo-dark"
        />
    </span>
    {isStacked ? (
        <span class="wordmark-text-img" role="img" aria-label="ChunkHound">
            <img
                src="/wordmark-text.svg"
                alt=""
                class="wordmark-text-img-light"
            />
            <img
                src="/wordmark-text-dark.svg"
                alt=""
                class="wordmark-text-img-dark"
            />
        </span>
    ) : (
        <span class="wordmark-text"
            >ChunkHound<span class="wordmark-dot" aria-hidden="true"></span></span
        >
    )}
</span>

<style>
    .wordmark-brand {
        font-family: "Inter", sans-serif;
        font-weight: 700;
        color: var(--text-primary);
    }

    /* Horizontal lockup — nav. Logo left, text right. */
    .wordmark-brand.horizontal {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        font-size: 18px;
    }

    @media (max-width: 420px) {
        .wordmark-brand.horizontal {
            font-size: 16px;
        }
    }

    /* Stacked lockup — hero. Logo on top, text below, both centered.
       Same on every viewport so the design matches README.md. */
    .wordmark-brand.stacked {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-4);
    }

    .wordmark-logo-stack {
        display: inline-grid;
        place-items: center;
        flex-shrink: 0;
    }

    /* Horizontal: scale by font-size. */
    .wordmark-brand.horizontal .wordmark-logo-stack {
        height: 1.4em;
        width: calc(1.4em * 194 / 150);
    }

    /* Stacked: scale by viewport, capped at README's 140px width. */
    .wordmark-brand.stacked .wordmark-logo-stack {
        width: clamp(72px, 14vw, 140px);
        aspect-ratio: 194 / 150;
    }

    .wordmark-logo {
        grid-area: 1 / 1;
        width: 100%;
        height: 100%;
    }

    .wordmark-logo-dark {
        display: none;
    }

    :global([data-theme="dark"]) .wordmark-logo-light {
        display: none;
    }

    :global([data-theme="dark"]) .wordmark-logo-dark {
        display: block;
    }

    /* Stacked variant renders the wordmark as a baked SVG (same asset the
       README uses) for pixel-parity between the two surfaces. */
    .wordmark-text-img {
        display: inline-grid;
        place-items: center;
        flex-shrink: 0;
        width: clamp(200px, 32vw, 320px);
        aspect-ratio: 122 / 34;
    }

    .wordmark-text-img-light,
    .wordmark-text-img-dark {
        grid-area: 1 / 1;
        width: 100%;
        height: 100%;
    }

    .wordmark-text-img-dark {
        display: none;
    }

    :global([data-theme="dark"]) .wordmark-text-img-light {
        display: none;
    }

    :global([data-theme="dark"]) .wordmark-text-img-dark {
        display: block;
    }

    /* Horizontal variant: HTML text + CSS dot. */
    .wordmark-text {
        position: relative;
        white-space: nowrap;
    }

    .wordmark-dot {
        display: inline-block;
        width: 0.14em;
        height: 0.14em;
        border-radius: 50%;
        background: var(--primary);
        margin-left: 1px;
        vertical-align: baseline;
    }
</style>
