---
import Wordmark from "./Wordmark.astro";
import { THEME_CMD, THEME_STRING } from '../lib/shiki-config.js';
---

<section class="hero">
    <div class="container">
        <h1 class="headline"><Wordmark size="lg" /></h1>
        <p class="tagline">Your entire codebase, deeply understood</p>
        <p class="subheadline">
            Multi-hop semantic search. Architecture research. Cited reports.
            Auto-generated documentation. The deepest code understanding
            available for AI agents.
        </p>
        <p class="amplifier">
            100% local · 33 languages · MIT licensed · Free forever
        </p>

        <div class="cta-row">
            <div class="install-pill">
                <code class="install-cmd">uv tool install chunkhound</code>
                <button
                    class="copy-btn"
                    onclick="navigator.clipboard.writeText('uv tool install chunkhound')"
                    aria-label="Copy install command"
                >
                    <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                        ></rect>
                        <path
                            d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"
                        ></path>
                    </svg>
                </button>
            </div>
            <a
                href="https://github.com/chunkhound/chunkhound"
                class="github-btn"
            >
                <svg
                    class="github-icon"
                    width="16"
                    height="16"
                    viewBox="0 0 16 16"
                    fill="currentColor"
                >
                    <path
                        d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
                    ></path>
                </svg>
                <span data-star-count>--</span>
                <svg
                    class="star-icon"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    stroke="none"
                >
                    <path
                        d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                    ></path>
                </svg>
            </a>
        </div>

        <div class="terminal-card">
            <div class="terminal-dots">
                <span class="dot red"></span>
                <span class="dot yellow"></span>
                <span class="dot green"></span>
            </div>
            <div class="terminal-lines">
                <div class="line">
                    <span class="prompt">$</span>
                    <span class="cmd">chunkhound index .</span>
                </div>
                <div class="line">
                    <span class="output"
                        >Indexed 12,847 files · 33 languages · 2.1M LOC</span
                    >
                </div>
                <div class="line">&nbsp;</div>
                <div class="line">
                    <span class="prompt">$</span>
                    <span class="cmd"
                        >chunkhound search <span class="str"
                            >"how does authentication work"</span
                        ></span
                    >
                </div>
                <div class="line">
                    <span class="output dim"
                        >Found 42 results via 3-hop semantic traversal</span
                    >
                </div>
                <div class="line">&nbsp;</div>
                <div class="line">
                    <span class="prompt">$</span>
                    <span class="cmd"
                        >chunkhound research <span class="str"
                            >"authentication architecture"</span
                        ></span
                    >
                </div>
                <div class="line">
                    <span class="output dim"
                        >Generated report · 14 files · 6 components · 23
                        citations<span class="cursor"></span></span
                    >
                </div>
            </div>
        </div>
    </div>
</section>

<style define:vars={{ themeCmd: THEME_CMD, themeString: THEME_STRING }}>
    .hero {
        padding: var(--space-10) 0;
        text-align: center;
    }

    .amplifier {
        font-size: var(--text-sm);
        line-height: var(--lh-sm);
        font-weight: 500;
        color: var(--text-secondary);
        letter-spacing: 0.02em;
        margin-bottom: var(--space-6);
    }

    .headline {
        margin-bottom: var(--space-2);
    }

    .tagline {
        font-size: var(--text-xl);
        line-height: var(--lh-xl);
        font-weight: 600;
        color: var(--text-secondary);
        margin-bottom: var(--space-4);
    }

    .subheadline {
        font-size: var(--text-lg);
        line-height: var(--lh-lg);
        font-weight: 500;
        color: var(--text-secondary);
        max-width: 640px;
        margin: 0 auto var(--space-6);
    }

    .cta-row {
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: center;
        gap: var(--space-3);
        flex-wrap: wrap;
    }

    .install-pill {
        background: var(--primary);
        border-radius: var(--radius-full);
        padding: var(--space-2) var(--space-5);
        display: flex;
        align-items: center;
        gap: var(--space-2);
    }

    .install-cmd {
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: var(--on-primary);
    }

    .copy-btn {
        background: none;
        border: none;
        color: var(--on-primary);
        cursor: pointer;
        padding: 0;
        display: flex;
        align-items: center;
        opacity: 0.8;
        transition: opacity 0.2s;
    }
    .copy-btn:hover {
        opacity: 1;
    }

    .github-btn {
        border: var(--border-w-default) solid var(--border-color);
        border-radius: var(--radius-full);
        padding: var(--space-2) var(--space-5);
        color: var(--text-primary);
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
    }
    .github-btn:hover {
        text-decoration: none;
    }

    .github-icon {
        flex-shrink: 0;
    }

    .star-icon {
        color: var(--primary-bright);
        flex-shrink: 0;
    }

    .terminal-card {
        background: var(--code-bg);
        border-radius: var(--radius-md);
        padding: var(--space-5);
        max-width: 600px;
        margin: var(--space-8) auto 0;
        text-align: left;
    }

    .terminal-dots {
        display: flex;
        gap: var(--space-2);
        margin-bottom: var(--space-4);
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }
    .dot.red {
        background: #ff5f56;
    }
    .dot.yellow {
        background: #ffbd2e;
    }
    .dot.green {
        background: #27c93f;
    }

    .terminal-lines {
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        line-height: 1.4;
    }

    .prompt {
        color: var(--text-muted);
    }
    .cmd {
        color: var(--themeCmd);
    }
    .output {
        color: var(--code-text);
    }
    .output.dim {
        opacity: 0.6;
    }
    .str {
        color: var(--themeString);
    }
    .result-idx {
        color: var(--primary-bright);
    }
    .score {
        color: var(--primary-bright);
    }

    .cursor {
        display: inline-block;
        width: 2px;
        height: 16px;
        background: var(--primary-bright);
        margin-left: 4px;
        vertical-align: text-bottom;
        animation: blink 1s step-end infinite;
    }

    @keyframes blink {
        0%,
        100% {
            opacity: 1;
        }
        50% {
            opacity: 0;
        }
    }
</style>
