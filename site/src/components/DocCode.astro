---
import { Code } from 'astro:components';
import CodeBlock from './CodeBlock.astro';
import { SHIKI_THEME } from '../lib/shiki-config.js';

interface Props {
    lang?: string;
    code: string;
}

const { lang = 'bash', code } = Astro.props;
---

<CodeBlock dataCopy={code}>
    <Code lang={lang} theme={SHIKI_THEME} code={code} />
</CodeBlock>
