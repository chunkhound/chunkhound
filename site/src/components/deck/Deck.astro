---
import SlideLayout from '../../layouts/SlideLayout.astro';

interface Props {
  title?: string;
}
const { title } = Astro.props;
---
<SlideLayout title={title}>
  <slot />
</SlideLayout>

<style is:global>
  .section-label {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  /* Deck: dark mode collapses text-muted/tertiary/secondary into primary
     because presentation slides use strong contrast for readability at a
     distance — subtle color distinctions are lost on projected screens. */
  [data-theme="dark"] .deck {
    --text-secondary: var(--text-primary);
    --text-tertiary: var(--text-primary);
    --text-muted: var(--text-primary);
  }
</style>
