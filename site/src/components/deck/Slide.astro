---
import SlideHeader from './SlideHeader.astro';

interface Props {
  layout?: "default" | "row" | "center";
  chrome?: "default" | "cover" | "footer";
  class?: string;
}
const { layout = "default", chrome = "default", class: extraClass } = Astro.props;

const bodyClass = [
  "slide-body",
  layout === "row" && "slide-body-row",
  layout === "center" && "slide-body-center",
].filter(Boolean).join(" ");

const sectionClass = ["slide", extraClass].filter(Boolean).join(" ");
const showTopHeader = chrome === "default" || chrome === "footer";
const showFooter = chrome === "footer" || chrome === "cover";
const hasFooterSlot = Astro.slots.has("footer");
---
<section class={sectionClass}>
  {showTopHeader && (
    Astro.slots.has("header") ? <slot name="header" /> : <SlideHeader />
  )}
  <div class={bodyClass}>
    <slot />
  </div>
  {showFooter && hasFooterSlot && <slot name="footer" />}
</section>

<style>
  .slide-body {
    padding: var(--space-5) var(--space-8);
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-4);
  }

  .slide-body-row {
    flex-direction: row;
    align-items: center;
    gap: var(--space-6);
  }

  .slide-body-center {
    justify-content: center;
  }
</style>
