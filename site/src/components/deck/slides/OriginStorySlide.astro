---
import Slide from '../Slide.astro';
---
<Slide layout="row">
  <div class="origin-left">
    <p class="section-label">ChunkHound</p>

    <div class="origin-meta">
      Weekend project · Solo<br>
      At home, 2025
    </div>

    <div class="origin-divider"></div>

    <div class="origin-growth">
      <span class="origin-stat">22 contributors</span>
      <span class="origin-sub">from around the globe · one year later</span>
    </div>
  </div>

  <div class="origin-right">
    <p class="adopters-label">In production today at</p>

    <div class="logo-cloud">
      <div class="logo-item logo-item--secondary logo-item--atlassian">
        <img src="/logos/atlassian.svg" alt="Atlassian" class="company-logo" />
        <span class="logo-name">Atlassian</span>
      </div>
      <div class="logo-item logo-item--secondary logo-item--riot">
        <img src="/logos/riot-games.svg" alt="Riot Games" class="company-logo" />
        <span class="logo-name">Riot Games</span>
      </div>
      <div class="logo-item logo-item--secondary logo-item--kimara">
        <img src="/logos/kimara-ai.svg" alt="KimaraAI" class="company-logo" />
        <span class="logo-name">KimaraAI</span>
      </div>
      <div class="logo-item logo-item--primary logo-item--applied">
        <img src="/logos/AMAT.svg" alt="" class="company-logo company-logo--amat" />
        <span class="logo-name">Applied Materials</span>
      </div>
      <div class="logo-item logo-item--primary logo-item--gov">
        <svg class="company-logo company-logo--icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z" />
        </svg>
        <span class="logo-name">U.S. Gov contractors</span>
      </div>
      <p class="and-others">+ and others</p>
    </div>
  </div>
</Slide>

<style>
  .origin-left {
    flex-shrink: 0;
    width: 35%;
    border-right: 1px solid var(--border-color);
    padding-right: var(--space-6);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-3);
  }

  .origin-meta {
    font-size: var(--text-xs);
    line-height: 1.8;
    color: var(--text-muted);
  }

  .origin-left .section-label {
    font-size: clamp(30px, 3.2vw, 44px);
    line-height: 1.1;
  }

  .origin-divider {
    width: 40%;
    height: 1px;
    background: var(--border-color);
  }

  .origin-growth {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .origin-stat {
    font-size: var(--text-sm);
    color: var(--primary);
    font-weight: 600;
  }

  .origin-sub {
    font-size: var(--text-xs);
    color: var(--text-secondary);
  }

  .origin-right {
    flex: 1;
    padding-left: var(--space-7);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-4);
    transform: translateY(var(--space-8));
  }

  /* Section Title Pattern — text-xs, 600, 0.12em, text-tertiary */
  .adopters-label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  /* Organic logo cloud — deliberately off-grid to feel like real-world adoption. */
  .logo-cloud {
    position: relative;
    width: min(100%, 620px);
    height: 320px;
    margin-top: calc(var(--space-2) * -1);
  }

  .logo-item {
    position: absolute;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .logo-item--primary {
    color: var(--text-primary);
  }

  .logo-item--secondary {
    color: var(--text-secondary);
    opacity: 0.72;
  }

  .company-logo {
    height: 24px;
    width: auto;
    max-width: 140px;
    filter: brightness(0) invert(var(--logo-invert));
    opacity: 0.82;
  }

  .company-logo--amat {
    width: 42px;
    height: 42px;
    max-width: none;
    object-fit: contain;
    opacity: 0.86;
  }

  svg.company-logo--icon {
    width: 34px;
    height: 34px;
    flex-shrink: 0;
  }

  .logo-name {
    font-size: var(--text-sm);
    color: currentColor;
    line-height: var(--lh-sm);
  }

  .logo-item--primary .logo-name {
    font-size: 23px;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .logo-item--applied {
    left: 20%;
    top: 39%;
  }

  .logo-item--gov {
    left: 46%;
    top: 62%;
  }

  .logo-item--atlassian {
    left: 52%;
    top: 10%;
  }

  .logo-item--riot {
    left: 10%;
    top: 18%;
  }

  .logo-item--kimara {
    left: 5%;
    top: 70%;
  }

  .logo-item--kimara .company-logo {
    height: 26px;
    max-width: 120px;
  }

  .logo-item--kimara .logo-name {
    display: none;
  }

  .and-others {
    position: absolute;
    left: 69%;
    top: 39%;
    margin: 0;
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }
</style>
