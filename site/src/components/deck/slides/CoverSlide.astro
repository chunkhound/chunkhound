---
import Slide from '../Slide.astro';
import Wordmark from '../../Wordmark.astro';
import ThemeToggle from '../../ThemeToggle.astro';

interface Props {
  tagline: string;
  meta: string;
  date: string;
}
const { tagline, meta, date } = Astro.props;
---
<Slide chrome="cover" class="slide-cover">
  <div class="cover-body">
    <Wordmark size="lg" />
    <p class="cover-tagline">{tagline}</p>
    <p class="cover-meta">{meta}</p>
  </div>
  <footer slot="footer" class="cover-footer">
    <div class="cover-footer-end">
      <ThemeToggle />
      <span class="slide-num" data-slide-num></span>
    </div>
    <span class="cover-date">{date}</span>
  </footer>
</Slide>

<style>
  :global(.slide-cover) {
    justify-content: space-between;
    background: var(--bg-page);
  }

  :global(.slide-cover) .slide-body {
    padding: 0;
  }

  .cover-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    padding: var(--space-8);
    text-align: center;
  }

  .cover-tagline {
    font-size: var(--text-xl);
    line-height: var(--lh-xl);
    font-weight: 600;
    color: var(--text-primary);
  }

  .cover-meta {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    letter-spacing: 0.06em;
  }

  .cover-footer {
    display: flex;
    justify-content: space-between;
    padding: var(--space-3) var(--space-6);
    border-top: var(--border-w-subtle) solid var(--border-subtle);
  }

  .cover-footer-end {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .slide-num {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .cover-date {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    font-weight: 600;
    letter-spacing: 0.12em;
  }
</style>
