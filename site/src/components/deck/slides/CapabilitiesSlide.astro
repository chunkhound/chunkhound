---
import Slide from '../Slide.astro';
import Chip from '../../Chip.astro';

interface Props {
  label: string;
  chips: string[];
  bullets: string[];
}
const { label, chips, bullets } = Astro.props;
---
<Slide>
  <p class="section-label">{label}</p>
  <div class="chip-row">
    {chips.map((c) => <Chip>{c}</Chip>)}
  </div>
  <ul class="cap-list">
    {bullets.map((b) => <li>{b}</li>)}
  </ul>
</Slide>

<style>
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .cap-list {
    list-style: disc;
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cap-list li {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--lh-sm);
  }
</style>
