---
import Slide from '../Slide.astro';

interface Props {
  label: string;
  bullets: Array<{ text: string; code?: string }>;
  url: string;
  note: string;
}
const { label, bullets, url, note } = Astro.props;
---
<Slide chrome="footer">
  <p class="section-label">{label}</p>
  <ul class="cta-list">
    {bullets.map((b) => (
      <li>
        {b.text}
        {b.code && <> <code>{b.code}</code></>}
      </li>
    ))}
  </ul>
  <footer slot="footer" class="slide-footer">
    <span class="footer-url">{url}</span>
    <span class="footer-note">{note}</span>
  </footer>
</Slide>

<style>
  .cta-list {
    list-style: disc;
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cta-list li {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--lh-base);
  }

  .cta-list code {
    background: var(--code-bg);
    color: var(--primary);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-sm);
  }

  .slide-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    border-top: var(--border-w-subtle) solid var(--border-subtle);
  }

  .footer-url {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--primary);
  }

  .footer-note {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    letter-spacing: 0.06em;
  }
</style>
