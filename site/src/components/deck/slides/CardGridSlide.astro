---
import Slide from '../Slide.astro';
import CardGrid from '../primitives/CardGrid.astro';
import Card from '../primitives/Card.astro';

interface Props {
  label: string;
  cards: Array<{ chip?: string; heading: string; body: string }>;
  columns?: 2 | 3;
}
const { label, cards, columns = 3 } = Astro.props;
---
<Slide>
  <p class="section-label">{label}</p>
  <CardGrid columns={columns}>
    {cards.map((card) => (
      <Card chip={card.chip} heading={card.heading}>{card.body}</Card>
    ))}
  </CardGrid>
</Slide>
