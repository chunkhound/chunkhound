---
import Slide from '../Slide.astro';
---

<Slide chrome="footer" layout="center" class="thank-you-slide">
  <div class="thank-you-lockup">
    <img src="/logo.svg" alt="" class="thank-you-logo" />
    <h1>Thank You<span class="thank-you-dot" aria-hidden="true"></span></h1>
  </div>
</Slide>

<style>
  .thank-you-slide :global(.slide-body) {
    padding: var(--space-8);
  }

  .thank-you-lockup {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
    width: 100%;
    min-height: 100%;
    text-align: center;
  }

  .thank-you-logo {
    width: clamp(180px, 24vw, 360px);
    height: auto;
    filter: brightness(0) invert(1);
  }

  :global([data-theme="light"]) .thank-you-logo {
    filter: none;
  }

  .thank-you-lockup h1 {
    margin: 0;
    color: var(--text-primary);
    font-size: clamp(56px, 7vw, 120px);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.05em;
  }

  .thank-you-lockup .thank-you-dot {
    display: inline-block;
    width: 0.14em;
    height: 0.14em;
    margin-left: 0.04em;
    border-radius: var(--radius-full);
    background: var(--primary-bright, #a1bc20);
    vertical-align: baseline;
  }

  @media (max-width: 640px) {
    .thank-you-slide :global(.slide-body) {
      padding: var(--space-6) var(--space-5);
    }

    .thank-you-lockup {
      gap: var(--space-5);
    }

    .thank-you-logo {
      width: clamp(144px, 48vw, 220px);
    }

    .thank-you-lockup h1 {
      font-size: clamp(44px, 14vw, 72px);
    }
  }
</style>
