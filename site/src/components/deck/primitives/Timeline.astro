---
import TimelineStep from './TimelineStep.astro';

interface Props {
  steps: Array<{ phase: string; desc: string }>;
}
const { steps } = Astro.props;
---
<div class="timeline">
  {steps.map((step, i) => (
    <>
      {i > 0 && <div class="timeline-connector"></div>}
      <TimelineStep phase={step.phase} desc={step.desc} />
    </>
  ))}
</div>

<style>
  .timeline {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .timeline-connector {
    flex: 1;
    height: 2px;
    background: var(--border-color);
    margin-bottom: calc(var(--space-2) + 4px + var(--space-2));
  }
</style>
