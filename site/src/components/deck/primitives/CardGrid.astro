---
interface Props {
  columns?: 2 | 3;
}
const { columns = 3 } = Astro.props;
---
<div class="card-grid" data-cols={columns}>
  <slot />
</div>

<style>
  .card-grid {
    display: grid;
    gap: var(--space-5);
  }
  .card-grid[data-cols="2"] {
    grid-template-columns: repeat(2, 1fr);
  }
  .card-grid[data-cols="3"] {
    grid-template-columns: repeat(3, 1fr);
  }
</style>
