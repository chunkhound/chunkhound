---
import Wordmark from '../Wordmark.astro';
import ThemeToggle from '../ThemeToggle.astro';
---
<header class="slide-header">
  <Wordmark size="sm" />
  <div class="slide-header-end">
    <span class="slide-num" data-slide-num></span>
    <ThemeToggle />
  </div>
</header>

<style>
  .slide-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    border-bottom: var(--border-w-subtle) solid var(--border-subtle);
    flex-shrink: 0;
  }

  .slide-header-end {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .slide-num {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }
</style>
