---
import type { MarkdownLayoutProps } from 'astro';
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import '../styles/docs.css';

type TocItem = {
  depth: 2 | 3;
  slug: string;
  text: string;
};

type MarkdownProps = MarkdownLayoutProps<{ title?: string; description?: string }> & {
  headings?: Array<{ depth: number; slug: string; text: string }>;
};
type DirectProps = { title?: string; description?: string; toc?: TocItem[] };
type Props = MarkdownProps | DirectProps;

const normalizeToc = (
  items: Array<{ depth: number; slug: string; text: string }> | undefined,
): TocItem[] =>
  (items ?? []).flatMap((item) =>
    (item.depth === 2 || item.depth === 3) && item.slug && item.text
      ? [{ depth: item.depth, slug: item.slug, text: item.text }]
      : [],
  );

const props = Astro.props as Props;
const title = 'frontmatter' in props ? props.frontmatter.title : props.title;
const description = 'frontmatter' in props ? props.frontmatter.description : props.description;
const pageTitle = title ? `${title} — ChunkHound Docs` : 'ChunkHound Docs';
const toc = 'toc' in props && props.toc?.length ? props.toc : normalizeToc('headings' in props ? props.headings : undefined);
---

<Base title={pageTitle} description={description}>
  <Nav currentPath={Astro.url.pathname} docsMenu />
  <div class="docs-shell">
    <DocsSidebar currentPath={Astro.url.pathname} />
    <div class="docs-nav-scrim" data-docs-nav-scrim></div>
    <main class="docs-main" data-docs-mobile-inert>
      {title && (
        <nav class="docs-breadcrumb" aria-label="Breadcrumb">
          <ph-book-open size="14" weight="duotone" aria-hidden="true"></ph-book-open>
          <a href="/docs/getting-started/">Guides</a>
          <ph-caret-right class="docs-breadcrumb-sep" size="12" weight="bold" aria-hidden="true"></ph-caret-right>
          <span aria-current="page">{title}</span>
        </nav>
      )}
      <article class="docs-content">
        <slot />
      </article>
    </main>
    <aside class="docs-toc" aria-label="On this page" data-docs-mobile-inert>
      <div class="toc-title"><ph-list-bullets size="16" weight="duotone" aria-hidden="true"></ph-list-bullets> On this page</div>
      <nav class="toc-list" data-toc>
        {toc.map((item) => (
          <a class="toc-link" href={`#${item.slug}`} data-depth={item.depth}>{item.text}</a>
        ))}
      </nav>
    </aside>
  </div>

  <script>
  import "@phosphor-icons/webcomponents/PhBookOpen";
  import "@phosphor-icons/webcomponents/PhCaretRight";
  import "@phosphor-icons/webcomponents/PhListBullets";
  import '../scripts/docs-runtime.ts';
  </script>
</Base>
