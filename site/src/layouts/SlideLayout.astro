---
interface Props {
  title?: string;
}
const { title = "ChunkHound" } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
  <script is:inline>
    (function () {
      var mq = window.matchMedia('(prefers-color-scheme: dark)');
      var html = document.documentElement;
      var params = new URLSearchParams(window.location.search);
      var themeOverride = params.get('theme');
      function resolve(setting) {
        if (setting === 'system') return mq.matches ? 'dark' : 'light';
        return setting;
      }
      function apply(setting) {
        html.setAttribute('data-theme-setting', setting);
        html.setAttribute('data-theme', resolve(setting));
        var btn = document.querySelector('.theme-toggle');
        if (btn) {
          var labels = { light: 'Switch to dark mode', dark: 'Switch to system theme', system: 'Switch to light mode' };
          btn.setAttribute('aria-label', labels[setting]);
        }
      }
      var saved = localStorage.getItem('theme');
      var initialSetting = themeOverride === 'light' || themeOverride === 'dark'
        ? themeOverride
        : saved === 'light' || saved === 'dark'
          ? saved
          : 'system';
      apply(initialSetting);
      mq.addEventListener('change', function () {
        if (html.getAttribute('data-theme-setting') === 'system') {
          html.setAttribute('data-theme', resolve('system'));
        }
      });
      var cycle = { light: 'dark', dark: 'system', system: 'light' };
      window.toggleTheme = function () {
        var next = cycle[html.getAttribute('data-theme-setting')] || 'system';
        localStorage.setItem('theme', next);
        apply(next);
      };
    })();
  </script>
  <style is:global>
    @page { size: 254mm 143mm; margin: 0; }
    * { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
    html, body { margin: 0; padding: 0; }

    :root {
      --text-xs:   clamp(14px, 1.2vw,  22px);  --lh-xs:   1.5;
      --text-sm:   clamp(20px, 1.8vw,  32px);  --lh-sm:   1.5;
      --text-base: clamp(24px, 2.2vw,  40px);  --lh-base: 1.5;
      --text-lg:   clamp(28px, 2.6vw,  46px);  --lh-lg:   1.4;
      --text-xl:   clamp(36px, 3.5vw,  62px);  --lh-xl:   1.3;
      --text-2xl:  clamp(44px, 4.5vw,  78px);  --lh-2xl:  1.2;
      --text-4xl:  clamp(72px, 8vw,   140px);  --lh-4xl:  1.15;
    }

    @media screen {
      html { height: 100%; overflow: hidden; }
      body { height: 100%; background: var(--bg-page); }
      .deck {
        height: 100svh;
        overflow-y: scroll;
        scroll-snap-type: y mandatory;
        overscroll-behavior-y: contain;
      }
      .slide {
        width: 100%;
        height: 100svh;
        scroll-snap-align: start;
        scroll-snap-stop: always;
        box-sizing: border-box;
        overflow: hidden;
        background: var(--bg-page);
        display: flex;
        flex-direction: column;
      }
    }

    @media print {
      body { height: auto; overflow: visible; }
      .slide {
        width: 100vw;
        height: 100vh;
        box-sizing: border-box;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        background: var(--bg-page);
        break-after: page;
        page-break-after: always;
        break-inside: avoid;
      }
      .slide:last-child {
        break-after: auto;
        page-break-after: auto;
      }
    }

    .theme-toggle {
      width: var(--target-sm);
      height: var(--target-sm);
      flex-shrink: 0;
      border: none;
      background: none;
      color: var(--text-secondary);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      border-radius: var(--radius-md);
      transition: color 0.2s, background-color 0.2s;
    }
    .theme-toggle:hover {
      color: var(--text-primary);
      background: var(--bg-muted);
    }
    .icon-sun, .icon-moon, .icon-system { display: none; }
    [data-theme-setting="light"] .icon-sun { display: block; }
    [data-theme-setting="dark"]  .icon-moon { display: block; }
    [data-theme-setting="system"] .icon-system { display: block; }

    @media print {
      .theme-toggle { display: none !important; }
    }
  </style>
</head>
<body>
<div class="deck"><slot /></div>
<script>
  const slides = Array.from(document.querySelectorAll('.slide'));
  let current = 0;

  function fillSlideNumbers() {
    const slots = document.querySelectorAll('.slide [data-slide-num]');
    const total = slides.length;

    slots.forEach((el) => {
      const slide = el.closest('.slide');
      if (!slide) return;
      const idx = slides.indexOf(slide);
      el.textContent = `${idx + 1} / ${total}`;
    });

    document.body.dataset.deckReady = '1';
  }

  function go(n) {
    const next = Math.max(0, Math.min(n, slides.length - 1));
    if (next === current) return;
    current = next;
    slides[current].scrollIntoView({ behavior: 'smooth' });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', fillSlideNumbers);
  } else {
    fillSlideNumbers();
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') go(current + 1);
    if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') go(current - 1);
  });
</script>
</body>
</html>
