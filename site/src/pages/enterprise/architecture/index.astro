        background: var(--green-bg);
    }
    .phase-card.in-progress {
        border-color: var(--primary);
    }
    .phase-card.in-progress .phase-badge {
        color: var(--on-primary);
        background: var(--primary);
    }
    .phase-card.future {
        border-color: var(--border-color);
    }
