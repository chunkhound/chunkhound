    .validation-callout li {
        color: var(--text-secondary);
        font-size: var(--text-sm);
        line-height: var(--lh-sm);
    }
    @media (max-width: 768px) {
        .index-maintenance-grid {
            grid-template-columns: 1fr;
        }
