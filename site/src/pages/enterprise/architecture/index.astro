        margin-top: var(--space-2);
        color: var(--text-tertiary);
        font-size: var(--text-xs);
    }
    .validation-callout {
        margin-top: var(--space-6);
        padding: var(--space-6);
        border-radius: var(--radius-xl);
        background: var(--primary-bg);
    }
