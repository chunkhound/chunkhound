#!/bin/sh
VERSION='0.0.0-chunkhound-sidecar-placeholder'

if [ "${1:-}" = "--version" ]; then
    printf 'watchman %s\n' "$VERSION"
    exit 0
fi

foreground=0
persistent=0
json_command=0
no_spawn=0
no_pretty=0
sockname=""
statefile=""
logfile=""
server_encoding=""
output_encoding=""

while [ $# -gt 0 ]; do
    case "$1" in
        --foreground)
            foreground=1
            shift
            ;;
        --no-save-state)
            shift
            ;;
        --persistent)
            persistent=1
            shift
            ;;
        --json-command)
            json_command=1
            shift
            ;;
        --no-spawn)
            no_spawn=1
            shift
            ;;
        --no-pretty)
            no_pretty=1
            shift
            ;;
        --sockname)
            sockname="$2"
            shift 2
            ;;
        --statefile)
            statefile="$2"
            shift 2
            ;;
        --logfile)
            logfile="$2"
            shift 2
            ;;
        --server-encoding)
            server_encoding="$2"
            shift 2
            ;;
        --output-encoding)
            output_encoding="$2"
            shift 2
            ;;
        *)
            printf '%s\n' "chunkhound fake watchman runtime: unsupported flag $1" >&2
            exit 64
            ;;
    esac
done

if [ "$persistent" = "1" ] || [ "$json_command" = "1" ] || [ "$no_spawn" = "1" ] || [ "$no_pretty" = "1" ] || [ -n "$server_encoding" ] || [ -n "$output_encoding" ]; then
    if [ "$foreground" = "1" ] || [ -n "$statefile" ] || [ -n "$logfile" ]; then
        printf '%s\n' 'chunkhound fake watchman runtime: unsupported mixed sidecar/client flags' >&2
        exit 64
    fi
    if [ -z "$sockname" ] || [ "$persistent" != "1" ] || [ "$json_command" != "1" ] || [ "$no_spawn" != "1" ] || [ "$no_pretty" != "1" ] || [ "$server_encoding" != "json" ] || [ "$output_encoding" != "json" ]; then
        printf '%s\n' 'chunkhound fake watchman runtime: missing client session flags' >&2
        exit 64
    fi
    export CHUNKHOUND_FAKE_WATCHMAN_SOCKNAME="$sockname"
    export CHUNKHOUND_FAKE_WATCHMAN_VERSION="$VERSION"
    exec python3 /dev/fd/3 3<<'PY'
from __future__ import annotations

import json
import os
import sys


def emit(payload: dict[str, object]) -> None:
    sys.stdout.write(json.dumps(payload, separators=(",", ":")) + "\n")
    sys.stdout.flush()


def capability_state(name: str, missing_capability: str | None) -> bool:
    return missing_capability != name


def main() -> int:
    version = os.environ["CHUNKHOUND_FAKE_WATCHMAN_VERSION"]
    sockname = os.environ["CHUNKHOUND_FAKE_WATCHMAN_SOCKNAME"]
    if not os.path.exists(sockname):
        print(
            "chunkhound fake watchman runtime: private socket is missing",
            file=sys.stderr,
        )
        return 69

    missing_capability = os.environ.get("CHUNKHOUND_FAKE_WATCHMAN_MISSING_CAPABILITY")
    watch_root_override = os.environ.get("CHUNKHOUND_FAKE_WATCHMAN_WATCH_ROOT")
    relative_path_override = (
        os.environ.get("CHUNKHOUND_FAKE_WATCHMAN_RELATIVE_PATH") or None
    )
    emit_pdu = os.environ.get("CHUNKHOUND_FAKE_WATCHMAN_EMIT_SUBSCRIPTION_PDU")
    emit_log = os.environ.get("CHUNKHOUND_FAKE_WATCHMAN_EMIT_LOG_AFTER_SUBSCRIBE")

    for raw_line in sys.stdin:
        line = raw_line.strip()
        if not line:
            continue
        try:
            command = json.loads(line)
        except json.JSONDecodeError:
            print(
                "chunkhound fake watchman runtime: invalid JSON command",
                file=sys.stderr,
            )
            return 65

        if not isinstance(command, list) or not command:
            emit({"error": "expected command array"})
            continue

        command_name = command[0]
        if command_name == "version":
            requested = []
            if len(command) > 1 and isinstance(command[1], dict):
                raw_requested = command[1].get("required")
                if isinstance(raw_requested, list):
                    requested = [str(item) for item in raw_requested]
            capabilities = {
                "cmd-watch-project": capability_state(
                    "cmd-watch-project", missing_capability
                ),
                "relative_root": capability_state("relative_root", missing_capability),
            }
            for name in requested:
                capabilities.setdefault(
                    name, capability_state(name, missing_capability)
                )
            emit({"version": version, "capabilities": capabilities})
            continue

        if command_name == "watch-project":
            if len(command) < 2:
                emit({"error": "watch-project requires a target path"})
                continue
            target_path = str(command[1])
            response: dict[str, object] = {
                "version": version,
                "watch": watch_root_override or target_path,
            }
            if relative_path_override not in {None, "", "."}:
                response["relative_path"] = relative_path_override.replace("\\", "/")
            emit(response)
            continue

        if command_name == "subscribe":
            if len(command) < 3:
                emit({"error": "subscribe requires a root and subscription name"})
                continue
            subscription_name = str(command[2])
            watch_root = str(command[1])
            emit({"version": version, "subscribe": subscription_name})
            if emit_log:
                emit({"log": emit_log})
            if emit_pdu:
                try:
                    payload = json.loads(emit_pdu)
                except json.JSONDecodeError:
                    payload = {
                        "subscription": subscription_name,
                        "root": watch_root,
                        "clock": "c:0:1",
                        "files": [
                            {
                                "name": "src/example.py",
                                "exists": True,
                                "new": True,
                                "type": "f",
                            }
                        ],
                    }
                if not isinstance(payload, dict):
                    payload = {
                        "subscription": subscription_name,
                        "root": watch_root,
                        "clock": "c:0:1",
                        "files": [],
                    }
                payload.setdefault("subscription", subscription_name)
                payload.setdefault("root", watch_root)
                emit(payload)
            continue

        emit({"error": f"unsupported command {command_name}"})

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
PY
fi

if [ "$foreground" != "1" ] || [ -z "$sockname" ] || [ -z "$statefile" ] || [ -z "$logfile" ]; then
    printf '%s\n' 'chunkhound fake watchman runtime: missing sidecar path flags' >&2
    exit 64
fi

delay_seconds="${CHUNKHOUND_FAKE_WATCHMAN_START_DELAY_SECONDS:-0}"
if [ "$delay_seconds" != "0" ]; then
    sleep "$delay_seconds"
fi

mkdir -p "$(dirname "$logfile")"
printf '%s\n' 'fake watchman start' >> "$logfile"

if [ "${CHUNKHOUND_FAKE_WATCHMAN_FAIL_BEFORE_READY:-0}" = "1" ]; then
    exit 70
fi

mkdir -p "$(dirname "$sockname")" "$(dirname "$statefile")"
printf '%s\n' 'socket ready' > "$sockname"
printf '%s\n' 'state ready' > "$statefile"

trap 'exit 0' TERM INT
while :; do
    sleep 1
done
