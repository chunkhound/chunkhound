# ChunkHound Docker environment configuration template.
# Copy this file to .env.docker and fill in real values before running docker compose.
# NEVER commit .env.docker — it is listed in .gitignore.

# ── Embedding provider ────────────────────────────────────────────────────────
CHUNKHOUND_EMBEDDING__PROVIDER=voyageai
CHUNKHOUND_EMBEDDING__MODEL=voyage-3.5
CHUNKHOUND_EMBEDDING__API_KEY=your-api-key-here
CHUNKHOUND_EMBEDDING__BASE_URL=
CHUNKHOUND_EMBEDDING__SSL_VERIFY=false

# ── Reranker (optional — improves semantic search ranking quality) ─────────────
CHUNKHOUND_EMBEDDING__RERANK_MODEL=/Qwen3-Reranker-8B
CHUNKHOUND_EMBEDDING__RERANK_URL=http://your-reranker-host:9009/rerank
CHUNKHOUND_EMBEDDING__RERANK_FORMAT=cohere
CHUNKHOUND_EMBEDDING__RERANK_SSL_VERIFY=false
CHUNKHOUND_EMBEDDING__RERANK_BATCH_SIZE=32
