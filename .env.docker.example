# ChunkHound Docker environment configuration template.
# Copy this file to .env.docker and fill in real values before running docker compose.
# NEVER commit .env.docker — it is listed in .gitignore.

# ── Host paths (fill in for this deployment host) ──────────────────────────────
# Absolute path to the host's .chunkhound.json, mounted read-only into every
# replica at /etc/chunkhound/config.json. One file, shared across replicas —
# it's read-only and read once at startup, so there's no need to copy it
# per-replica the way chunks.db is (DuckDB's exclusive lock is what forces the
# per-replica DB copies, not anything about this file).
CHUNKHOUND_CONFIG_HOST_PATH=/home/youruser/path/to/.chunkhound.json
# Host's Claude Code credentials, mounted read-only into every replica.
CLAUDE_HOME_JSON_PATH=/home/youruser/.claude.json
CLAUDE_HOME_DIR_PATH=/home/youruser/.claude
# UID/GID the container's `chunkhound` user is created with (docker/Dockerfile),
# so files written by the container match ownership on host-mounted volumes.
# Run `id -u`/`id -g` on the deployment host to find these.
HOST_UID=1000
HOST_GID=1000

# ── Claude Code CLI ───────────────────────────────────────────────────────────
CLAUDE_CLI_MODULE_PATH=/path/to/@amat-ai/claude-code
# Applied Materials business unit — required by the AMAT Claude CLI fork.
# Valid values: AGS, GIS, SPG, PDC, IPC, DEFAULT
AMAT_BU=PDC

# ── Embedding provider ────────────────────────────────────────────────────────
CHUNKHOUND_EMBEDDING__PROVIDER=voyageai
CHUNKHOUND_EMBEDDING__MODEL=voyage-3.5
CHUNKHOUND_EMBEDDING__API_KEY=your-api-key-here
CHUNKHOUND_EMBEDDING__BASE_URL=
CHUNKHOUND_EMBEDDING__SSL_VERIFY=false

# ── Reranker (optional — improves semantic search ranking quality) ─────────────
CHUNKHOUND_EMBEDDING__RERANK_MODEL=/Qwen3-Reranker-8B
CHUNKHOUND_EMBEDDING__RERANK_URL=http://your-reranker-host:9009/rerank
CHUNKHOUND_EMBEDDING__RERANK_FORMAT=cohere
CHUNKHOUND_EMBEDDING__RERANK_SSL_VERIFY=false
CHUNKHOUND_EMBEDDING__RERANK_BATCH_SIZE=32
